@model IEnumerable<MiniMarketApp.ViewModels.PromedioVentaClienteDto>
@{
    ViewData["Title"] = "Promedio de Ventas por Cliente";
}

<div class="container mt-4">
    <h2>Top 20 Promedio de Ventas por Cliente</h2><button onclick="exportarPDF()" class="btn btn-danger btn-export-pdf mb-3"><i class="bi bi-file-earmark-pdf-fill"></i> Exportar a PDF</button><div id="reporte-pdf">
    <table class="table table-striped table-bordered mt-3">
        <thead class="table-dark">
            <tr>
                <th>Cliente</th>
                <th>Promedio de Ventas</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.Cliente</td>
                    <td>@item.PromedioVentas.ToString("C")</td>
                </tr>
            }
        </tbody>
    </table>
    <a asp-action="Index" class="btn btn-secondary mt-3"><i class="bi bi-arrow-left"></i> Volver a Reportes</a>
</div>


</div><script>function exportarPDF() { var element = document.getElementById("reporte-pdf"); var opt = { margin: 0.5, filename: "Reporte.pdf", image: { type: "jpeg", quality: 0.98 }, html2canvas: { scale: 2 }, jsPDF: { unit: "in", format: "letter", orientation: "portrait" } }; html2pdf().set(opt).from(element).save(); }</script>
</div><script>function exportarPDF() { var element = document.getElementById("reporte-pdf"); var opt = { margin: 0.5, filename: "Reporte.pdf", image: { type: "jpeg", quality: 0.98 }, html2canvas: { scale: 2 }, jsPDF: { unit: "in", format: "letter", orientation: "portrait" } }; html2pdf().set(opt).from(element).save(); }</script>
