@model MiniMarketApp.ViewModels.ResumenGeneralDto
@{
    ViewData["Title"] = "Resumen General";
}

<div class="container mt-4">
    <h2>Resumen General del Sistema</h2><button onclick="exportarPDF()" class="btn btn-danger btn-export-pdf mb-3"><i class="bi bi-file-earmark-pdf-fill"></i> Exportar a PDF</button><div id="reporte-pdf">
    <div class="row mt-4">
        <div class="col-md-4">
            <div class="card text-white bg-primary mb-3">
                <div class="card-header">Clientes</div>
                <div class="card-body">
                    <h5 class="card-title">Activos: @Model.ClientesActivos</h5>
                    <p class="card-text">Inactivos: @Model.ClientesInactivos</p>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card text-white bg-success mb-3">
                <div class="card-header">Productos</div>
                <div class="card-body">
                    <h5 class="card-title">Activos: @Model.ProductosActivos</h5>
                    <p class="card-text">Inactivos: @Model.ProductosInactivos</p>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card text-white bg-info mb-3">
                <div class="card-header">Ventas Totales</div>
                <div class="card-body">
                    <h5 class="card-title">Activas: @Model.VentasActivas</h5>
                    <p class="card-text">Anuladas/Inactivas: @Model.VentasInactivas</p>
                </div>
            </div>
        </div>
    </div>
    <div class="row">
        <div class="col-md-6">
            <div class="card border-warning mb-3">
                <div class="card-header bg-warning text-dark">Ventas del Último Mes</div>
                <div class="card-body">
                    <h5 class="card-title">Total de Transacciones: @Model.TotalVentasUltimoMes</h5>
                    <p class="card-text">Ingresos Generados: @Model.TotalIngresosUltimoMes.ToString("C")</p>
                </div>
            </div>
        </div>
    </div>
    
    <a asp-action="Index" class="btn btn-secondary mt-3"><i class="bi bi-arrow-left"></i> Volver a Reportes</a>
</div>


</div><script>function exportarPDF() { var element = document.getElementById("reporte-pdf"); var opt = { margin: 0.5, filename: "Reporte.pdf", image: { type: "jpeg", quality: 0.98 }, html2canvas: { scale: 2 }, jsPDF: { unit: "in", format: "letter", orientation: "portrait" } }; html2pdf().set(opt).from(element).save(); }</script>
</div><script>function exportarPDF() { var element = document.getElementById("reporte-pdf"); var opt = { margin: 0.5, filename: "Reporte.pdf", image: { type: "jpeg", quality: 0.98 }, html2canvas: { scale: 2 }, jsPDF: { unit: "in", format: "letter", orientation: "portrait" } }; html2pdf().set(opt).from(element).save(); }</script>
