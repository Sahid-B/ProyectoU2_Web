@{
    ViewData["Title"] = "Centro de Reportes";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="text-primary fw-bold"><i class="bi bi-bar-chart-fill"></i> Centro de Reportes</h2>
    </div>

    <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
        <!-- 1 -->
        <div class="col">
            <div class="card h-100 shadow-sm border-0 rounded-4 card-hover">
                <div class="card-body text-center p-4">
                    <div class="display-4 text-primary mb-3"><i class="bi bi-cash-stack"></i></div>
                    <h5 class="card-title fw-bold">Total de Ventas</h5>
                    <p class="card-text text-muted">Resumen general de los ingresos generados por ventas totales.</p>
                    <a asp-action="TotalVentas" class="btn btn-outline-primary rounded-pill w-100 mt-2">Ver Reporte</a>
                </div>
            </div>
        </div>
        <!-- 2 -->
        <div class="col">
            <div class="card h-100 shadow-sm border-0 rounded-4 card-hover">
                <div class="card-body text-center p-4">
                    <div class="display-4 text-success mb-3"><i class="bi bi-calendar-check"></i></div>
                    <h5 class="card-title fw-bold">Ventas por Mes</h5>
                    <p class="card-text text-muted">Análisis detallado de ventas agrupadas mensualmente.</p>
                    <a asp-action="VentasPorMes" class="btn btn-outline-success rounded-pill w-100 mt-2">Ver Reporte</a>
                </div>
            </div>
        </div>
        <!-- 3 -->
        <div class="col">
            <div class="card h-100 shadow-sm border-0 rounded-4 card-hover">
                <div class="card-body text-center p-4">
                    <div class="display-4 text-danger mb-3"><i class="bi bi-star-fill"></i></div>
                    <h5 class="card-title fw-bold">Top 10 Productos</h5>
                    <p class="card-text text-muted">Los artículos más vendidos y populares del minimarket.</p>
                    <a asp-action="TopProductos" class="btn btn-outline-danger rounded-pill w-100 mt-2">Ver Reporte</a>
                </div>
            </div>
        </div>
        <!-- 4 -->
        <div class="col">
            <div class="card h-100 shadow-sm border-0 rounded-4 card-hover">
                <div class="card-body text-center p-4">
                    <div class="display-4 text-warning mb-3"><i class="bi bi-people-fill"></i></div>
                    <h5 class="card-title fw-bold">Top 10 Clientes</h5>
                    <p class="card-text text-muted">Nuestros mejores clientes frecuentes por volumen de compras.</p>
                    <a asp-action="ClientesMasCompras" class="btn btn-outline-warning rounded-pill w-100 mt-2">Ver Reporte</a>
                </div>
            </div>
        </div>
        <!-- 5 -->
        <div class="col">
            <div class="card h-100 shadow-sm border-0 rounded-4 card-hover">
                <div class="card-body text-center p-4">
                    <div class="display-4 text-danger mb-3"><i class="bi bi-exclamation-triangle-fill"></i></div>
                    <h5 class="card-title fw-bold">Bajo Stock</h5>
                    <p class="card-text text-muted">Productos que requieren reabastecimiento urgente.</p>
                    <a asp-action="ProductosBajoStock" class="btn btn-outline-danger rounded-pill w-100 mt-2">Ver Reporte</a>
                </div>
            </div>
        </div>
        <!-- 6 -->
        <div class="col">
            <div class="card h-100 shadow-sm border-0 rounded-4 card-hover">
                <div class="card-body text-center p-4">
                    <div class="display-4 text-info mb-3"><i class="bi bi-geo-alt-fill"></i></div>
                    <h5 class="card-title fw-bold">Ventas por Estado</h5>
                    <p class="card-text text-muted">Estado actual de las ventas (completadas, pendientes, canceladas).</p>
                    <a asp-action="VentasPorEstado" class="btn btn-outline-info rounded-pill w-100 mt-2">Ver Reporte</a>
                </div>
            </div>
        </div>
        <!-- 7 -->
        <div class="col">
            <div class="card h-100 shadow-sm border-0 rounded-4 card-hover">
                <div class="card-body text-center p-4">
                    <div class="display-4 text-secondary mb-3"><i class="bi bi-truck"></i></div>
                    <h5 class="card-title fw-bold">Top 10 Proveedores</h5>
                    <p class="card-text text-muted">Nuestros proveedores principales por cantidad de productos provistos.</p>
                    <a asp-action="ProveedoresMasProductos" class="btn btn-outline-secondary rounded-pill w-100 mt-2">Ver Reporte</a>
                </div>
            </div>
        </div>
        <!-- 8 -->
        <div class="col">
            <div class="card h-100 shadow-sm border-0 rounded-4 card-hover">
                <div class="card-body text-center p-4">
                    <div class="display-4 text-primary mb-3"><i class="bi bi-tags-fill"></i></div>
                    <h5 class="card-title fw-bold">Top 10 Categorías</h5>
                    <p class="card-text text-muted">Las categorías de productos más vendidas y rentables.</p>
                    <a asp-action="CategoriasMasVendidas" class="btn btn-outline-primary rounded-pill w-100 mt-2">Ver Reporte</a>
                </div>
            </div>
        </div>
        <!-- 9 -->
        <div class="col">
            <div class="card h-100 shadow-sm border-0 rounded-4 card-hover">
                <div class="card-body text-center p-4">
                    <div class="display-4 text-success mb-3"><i class="bi bi-graph-up-arrow"></i></div>
                    <h5 class="card-title fw-bold">Promedio Ventas/Cliente</h5>
                    <p class="card-text text-muted">Ticket promedio de compras por cliente frecuente.</p>
                    <a asp-action="PromedioVentasPorCliente" class="btn btn-outline-success rounded-pill w-100 mt-2">Ver Reporte</a>
                </div>
            </div>
        </div>
        <!-- 10 -->
        <div class="col">
            <div class="card h-100 shadow-sm border-0 rounded-4 card-hover bg-primary text-white">
                <div class="card-body text-center p-4">
                    <div class="display-4 text-white mb-3"><i class="bi bi-pie-chart-fill"></i></div>
                    <h5 class="card-title fw-bold">Resumen General</h5>
                    <p class="card-text text-light">Dashboard general de métricas clave del sistema completo.</p>
                    <a asp-action="ResumenGeneral" class="btn btn-light text-primary fw-bold rounded-pill w-100 mt-2">Ver Reporte Global</a>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
.card-hover:hover {
    transform: translateY(-5px);
    box-shadow: 0 10px 20px rgba(0,0,0,0.1) !important;
}
</style>


