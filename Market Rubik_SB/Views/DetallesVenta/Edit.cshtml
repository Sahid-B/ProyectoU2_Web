@model MiniMarketApp.Models.DetalleVenta

@{
    ViewData["Title"] = "Editar";
}

<h2 class="mb-4 text-warning fw-bold">Editar Registro</h2>
<div class="row justify-content-center"><div class="col-md-8"><div class="card shadow-sm border-0 rounded-4"><div class="card-body p-4 p-md-5 bg-white">
        <form asp-action="Edit">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <input type="hidden" asp-for="Id" />
            <div class="form-group mb-3">
                <label asp-for="VentaId" class="control-label fw-bold text-muted mb-1"></label>
                <select asp-for="VentaId" class="form-control form-control-lg bg-light" asp-items="ViewBag.VentaId"></select>
                <span asp-validation-for="VentaId" class="text-danger"></span>
            </div>
            <div class="form-group mb-3">
                <label asp-for="ProductoId" class="control-label fw-bold text-muted mb-1"></label>
                <select asp-for="ProductoId" class="form-control form-control-lg bg-light" asp-items="ViewBag.ProductoId"></select>
                <span asp-validation-for="ProductoId" class="text-danger"></span>
            </div>
            <div class="form-group mb-3">
                <label asp-for="Cantidad" class="control-label fw-bold text-muted mb-1"></label>
                <input asp-for="Cantidad" class="form-control form-control-lg bg-light" />
                <span asp-validation-for="Cantidad" class="text-danger"></span>
            </div>
            <div class="form-group mb-3">
                <label asp-for="PrecioUnitario" class="control-label fw-bold text-muted mb-1"></label>
                <input asp-for="PrecioUnitario" class="form-control form-control-lg bg-light" />
                <span asp-validation-for="PrecioUnitario" class="text-danger"></span>
            </div>
            <div class="form-group mb-3">
                <label asp-for="FechaCreacion" class="control-label fw-bold text-muted mb-1"></label>
                <input asp-for="FechaCreacion" class="form-control form-control-lg bg-light" />
                <span asp-validation-for="FechaCreacion" class="text-danger"></span>
            </div>
            <div class="form-group mb-3">
                <button type="submit" class="btn btn-warning rounded-pill px-4 shadow-sm"><i class="bi bi-save"></i> Guardar Cambios</button>
            </div>
        </form></div></div></div></div><div class="mt-4"><a asp-action="Index" class="btn btn-secondary mt-3"><i class="bi bi-arrow-left"></i> Volver a la lista</a>
</div>





