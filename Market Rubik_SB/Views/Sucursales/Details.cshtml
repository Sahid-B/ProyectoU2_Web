@model MiniMarketApp.Models.Sucursal

@{
    ViewData["Title"] = "Detalles de Sucursal";
}

<h2 class="mb-4 text-primary fw-bold">Detalles de la Sucursal</h2>

<div class="card shadow-sm border-0 rounded-4 mb-4">
    <div class="card-body p-4 p-md-5 bg-white">
        <dl class="row mb-0">
            <dt class="col-sm-3 text-muted">@Html.DisplayNameFor(model => model.Nombre)</dt>
            <dd class="col-sm-9 fw-bold fs-5">@Html.DisplayFor(model => model.Nombre)</dd>
            
            <dt class="col-sm-3 text-muted">@Html.DisplayNameFor(model => model.Direccion)</dt>
            <dd class="col-sm-9">@Html.DisplayFor(model => model.Direccion)</dd>
            
            <dt class="col-sm-3 text-muted">@Html.DisplayNameFor(model => model.Telefono)</dt>
            <dd class="col-sm-9">@Html.DisplayFor(model => model.Telefono)</dd>
            
            <dt class="col-sm-3 text-muted">@Html.DisplayNameFor(model => model.Activo)</dt>
            <dd class="col-sm-9">
                @if (Model.Activo)
                {
                    <span class="badge bg-success">Activo</span>
                }
                else
                {
                    <span class="badge bg-danger">Inactivo</span>
                }
            </dd>
            
            <dt class="col-sm-3 text-muted mt-3">@Html.DisplayNameFor(model => model.FechaCreacion)</dt>
            <dd class="col-sm-9 mt-3 text-secondary">@Html.DisplayFor(model => model.FechaCreacion)</dd>
        </dl>
    </div>
</div>

<div class="mt-3">
    @if (Context.Session.GetString("Rol") == "Admin") { <a asp-action="Edit" asp-route-id="@Model?.Id" class="btn btn-primary rounded-pill px-4"><i class="bi bi-pencil-square"></i> Editar</a> }
    <a asp-action="Index" class="btn btn-secondary rounded-pill px-4 ms-2"><i class="bi bi-arrow-left"></i> Volver a la lista</a>
</div>
