@model MiniMarketApp.Models.Sucursal

@{
    ViewData["Title"] = "Eliminar Sucursal";
}

<h2 class="mb-4 text-danger fw-bold">Eliminar Registro</h2>

<div class="alert alert-warning shadow-sm border-0 rounded-4 mb-4">
    <h4 class="alert-heading fw-bold"><i class="bi bi-exclamation-triangle"></i> ¿Está seguro que desea eliminar esto?</h4>
    <p class="mb-0">Esta acción no borrará los datos permanentemente, sino que los marcará como inactivos (eliminación lógica).</p>
</div>

<div class="card shadow-sm border-0 rounded-4 mb-4 border-start border-danger border-4">
    <div class="card-body p-4 bg-white">
        <dl class="row mb-0">
            <dt class="col-sm-3 text-muted">@Html.DisplayNameFor(model => model.Nombre)</dt>
            <dd class="col-sm-9 fw-bold fs-5">@Html.DisplayFor(model => model.Nombre)</dd>
            
            <dt class="col-sm-3 text-muted">@Html.DisplayNameFor(model => model.Direccion)</dt>
            <dd class="col-sm-9">@Html.DisplayFor(model => model.Direccion)</dd>
            
            <dt class="col-sm-3 text-muted">@Html.DisplayNameFor(model => model.Telefono)</dt>
            <dd class="col-sm-9">@Html.DisplayFor(model => model.Telefono)</dd>
        </dl>
    </div>
</div>

<div class="mt-4">
    <form asp-action="Delete">
        <input type="hidden" asp-for="Id" />
        <button type="submit" class="btn btn-danger rounded-pill px-4 shadow-sm"><i class="bi bi-trash"></i> Sí, Eliminar</button>
        <a asp-action="Index" class="btn btn-secondary rounded-pill px-4 ms-2"><i class="bi bi-x-circle"></i> Cancelar</a>
    </form>
</div>
