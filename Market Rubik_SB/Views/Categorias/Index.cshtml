@model IEnumerable<MiniMarketApp.Models.Categoria>

@{
    ViewData["Title"] = "Listado";
}

<div class="d-flex justify-content-between align-items-center mb-4"><h2 class="text-primary fw-bold m-0">Listado de Registros</h2></div>

@if (Context.Session.GetString("Rol") == "Admin") {<p>
    <a asp-action="Create" class="btn btn-primary mb-3"><i class="bi bi-plus-circle"></i> Nuevo Registro</a>
</p>}
<form method="get" class="d-flex mb-3">
    <input type="text" name="buscar" value="@ViewBag.Buscar"
           class="form-control me-2" placeholder="Buscar..." />
    <button type="submit" class="btn btn-outline-primary"><i class="bi bi-search"></i> Buscar</button>
</form>

<p>Total: @ViewBag.Paginacion.TotalRegistros registros —
   Página @ViewBag.Paginacion.PaginaActual de @ViewBag.Paginacion.TotalPaginas</p>

<nav>
    <ul class="pagination">
        @if (ViewBag.Paginacion.TienePaginaAnterior)
        {
            <li class="page-item">
                <a class="page-link" asp-action="Index"
                   asp-route-pagina="@(ViewBag.Paginacion.PaginaActual - 1)"
                   asp-route-buscar="@ViewBag.Buscar">Anterior</a>
            </li>
        }
        @if (ViewBag.Paginacion.TienePaginaSiguiente)
        {
            <li class="page-item">
                <a class="page-link" asp-action="Index"
                   asp-route-pagina="@(ViewBag.Paginacion.PaginaActual + 1)"
                   asp-route-buscar="@ViewBag.Buscar">Siguiente</a>
            </li>
        }
    </ul>
</nav>


<table class="table">
    <thead>
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.Nombre)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Descripcion)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Activo)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.FechaCreacion)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.FechaActualizacion)
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model) {
        <tr>
            <td>
                @Html.DisplayFor(modelItem => item.Nombre)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Descripcion)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Activo)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.FechaCreacion)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.FechaActualizacion)
            </td>
            <td>
                @if (Context.Session.GetString("Rol") == "Admin") { <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary">Editar</a> } <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-info">Detalles</a> @if (Context.Session.GetString("Rol") == "Admin") { <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger">Eliminar</a> }
            </td>
        </tr>
}
    </tbody>
</table>








