@model MiniMarketApp.Models.Producto

@{
    ViewData["Title"] = "Editar";
}

<h2 class="mb-4 text-warning fw-bold">Editar Registro</h2>
<div class="row justify-content-center"><div class="col-md-8"><div class="card shadow-sm border-0 rounded-4"><div class="card-body p-4 p-md-5 bg-white">
        <form asp-action="Edit">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <input type="hidden" asp-for="Id" />
            <div class="form-group mb-3">
                <label asp-for="Nombre" class="control-label fw-bold text-muted mb-1"></label>
                <input asp-for="Nombre" class="form-control form-control-lg bg-light" />
                <span asp-validation-for="Nombre" class="text-danger"></span>
            </div>
            <div class="form-group mb-3">
                <label asp-for="Descripcion" class="control-label fw-bold text-muted mb-1"></label>
                <input asp-for="Descripcion" class="form-control form-control-lg bg-light" />
                <span asp-validation-for="Descripcion" class="text-danger"></span>
            </div>
            <div class="form-group mb-3">
                <label asp-for="Precio" class="control-label fw-bold text-muted mb-1"></label>
                <input asp-for="Precio" class="form-control form-control-lg bg-light" />
                <span asp-validation-for="Precio" class="text-danger"></span>
            </div>
            <div class="form-group mb-3">
                <label asp-for="Stock" class="control-label fw-bold text-muted mb-1"></label>
                <input asp-for="Stock" class="form-control form-control-lg bg-light" />
                <span asp-validation-for="Stock" class="text-danger"></span>
            </div>
            <div class="form-group mb-3">
                <label asp-for="CategoriaId" class="control-label fw-bold text-muted mb-1"></label>
                <select asp-for="CategoriaId" class="form-control form-control-lg bg-light" asp-items="ViewBag.CategoriaId"></select>
                <span asp-validation-for="CategoriaId" class="text-danger"></span>
            </div>
            <div class="form-group mb-3">
                <label asp-for="ProveedorId" class="control-label fw-bold text-muted mb-1"></label>
                <select asp-for="ProveedorId" class="form-control form-control-lg bg-light" asp-items="ViewBag.ProveedorId"></select>
                <span asp-validation-for="ProveedorId" class="text-danger"></span>
            </div>
            <div class="form-group form-check">
                <label class="form-check-label">
                    <input class="form-check-input" asp-for="Activo" /> @Html.DisplayNameFor(model => model.Activo)
                </label>
            </div>
            <div class="form-group mb-3">
                <label asp-for="FechaCreacion" class="control-label fw-bold text-muted mb-1"></label>
                <input asp-for="FechaCreacion" class="form-control form-control-lg bg-light" />
                <span asp-validation-for="FechaCreacion" class="text-danger"></span>
            </div>
            <div class="form-group mb-3">
                <label asp-for="FechaActualizacion" class="control-label fw-bold text-muted mb-1"></label>
                <input asp-for="FechaActualizacion" class="form-control form-control-lg bg-light" />
                <span asp-validation-for="FechaActualizacion" class="text-danger"></span>
            </div>
            <div class="form-group mb-3">
                <button type="submit" class="btn btn-warning rounded-pill px-4 shadow-sm"><i class="bi bi-save"></i> Guardar Cambios</button>
            </div>
        </form></div></div></div></div><div class="mt-4"><a asp-action="Index" class="btn btn-secondary mt-3"><i class="bi bi-arrow-left"></i> Volver a la lista</a>
</div>





